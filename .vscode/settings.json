{
    "latex-workshop.latex.tools": [
        {
            "name": "latexmk",
            "command": "latexmk",
            "args": [
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "-pdf",
                "-outdir=%OUTDIR%",
                "%DOC%"
            ],
            "env": {
                "PATH": "/Library/TeX/texbin:/usr/local/texlive/2025/bin/universal-darwin:%PATH%"
            }
        }
    ],
    "latex-workshop.latex.rootFile": "thesis/main.tex",
    "latex-workshop.view.pdf.viewer": "tab"
}
